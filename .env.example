# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# Home auth is auto-detected by default:
# - Codex: ~/.codex/auth.json
# - Claude: ~/.claude/.credentials.json
# - Gemini: ~/.gemini/oauth_creds.json (used by gemini/* via Gemini CLI / Code Assist)

# Optional auth path overrides
CODEX_AUTH_PATH=
CLAUDE_AUTH_PATH=
GEMINI_AUTH_PATH=

# Large output / large file handling
EXEC_OUTPUT_SPILL_THRESHOLD_BYTES=65536
READ_FILE_SPILL_THRESHOLD_BYTES=262144
ARTIFACT_PREVIEW_BYTES=8192
